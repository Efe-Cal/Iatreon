FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    REDIS_HOST=redis \
    REDIS_PORT=6379

COPY pdf_worker/requirements-api.txt /app/pdf_worker/requirements-api.txt
RUN pip install --no-cache-dir -r /app/pdf_worker/requirements-api.txt

COPY pdf_worker/api.py pdf_worker/security.py /app/pdf_worker/

EXPOSE 8000

CMD ["uvicorn", "pdf_worker.api:app", "--host", "0.0.0.0", "--port", "8000"]
