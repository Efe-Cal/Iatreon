#back_to_chat {
    width: auto;
    margin: 0;
    padding: 0;
    min-width: 0;
    height: auto;
    border: none;
}

#research_tabs {
    height: 1fr;
}

#research_report_container {
    height: 1fr;
    margin: 1;
}

#source_viewer {
    height: 1fr;
    margin: 1;
}

#research_markdown MarkdownH6 {
    color: transparent;
    width: 0;
    height: 1;
    margin: 0 0;
    padding: 0 0;
    border: none;
}